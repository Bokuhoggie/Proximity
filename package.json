{
  "name": "proximity",
  "version": "0.2.0",
  "description": "Voice and chat for friends",
  "main": "src/main/main.js",
  "scripts": {
    "start": "node src/server/signaling-server.js",
    "server": "node src/server/signaling-server.js",
    "electron": "electron .",
    "dev": "electron . --dev",
    "dev:all": "concurrently --kill-others --names server,app -c green,cyan \"npm run server\" \"npm run dev\"",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "Bokuhoggie",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "build": {
    "appId": "com.bokuhoggie.proximity",
    "productName": "Proximity",
    "directories": { "output": "dist-electron" },
    "files": [
      "src/main/**/*",
      "src/renderer/**/*",
      "node_modules/**/*",
      "assets/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "mac": {
      "icon": "assets/icon.icns",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [{ "target": "AppImage", "arch": ["x64"] }]
    }
  }
}
